#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force frankenphp .
mise cache clear
mise install frankenphp@1.12.1

# Capture and display the output while also verifying it
output=$(mise exec "frankenphp@1.12.1" -- "frankenphp" --version)
echo "frankenphp output: ${output}"

if echo "${output}" | grep -q '1.12.1'; then
  echo "✓ Tests passed"
else
  echo "✗ Test failed: expected version frankenphp@1.12.1"
  exit 1
fi
